{
  "name": "flood-prediction-system",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=backend",
    "start": "npm run start --workspace=backend",
    "build": "npm run backend:build && npm run frontend:build",
    "backend:build": "npm run build --workspace=backend",
    "backend:start": "npm start --workspace=backend",
    "frontend:build": "npm run build --workspace=frontend",
    "frontend:dev": "npm run dev --workspace=frontend",
    "lint": "npm run lint --workspace=backend && npm run lint --workspace=frontend"
  },
  "dependencies": {
    "typescript-eslint": "^8.57.1"
  }
}
